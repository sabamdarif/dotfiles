#!/usr/bin/env bash

ROFI_THEME="$HOME/.config/rofi/wifi-menu.rasi"
ROFI_PASSWORD_THEME="$HOME/.config/rofi/wifi-password.rasi"
LOG_FILE="$HOME/.cache/wifi-manager.log"
WIFI_INTERFACE=""

log() {
    local level="$1"
    shift
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] [$level] $*" >>"$LOG_FILE"
}

get_wifi_interface() {
    if [[ -z "$WIFI_INTERFACE" ]]; then
        WIFI_INTERFACE=$(nmcli -t -f DEVICE,TYPE device | grep ':wifi$' | cut -d: -f1 | head -1)
    fi
    echo "$WIFI_INTERFACE"
}

mkdir -p "$(dirname "$LOG_FILE")"
log "INFO" "==================== WiFi Manager Started ===================="

is_wifi_enabled() {
    [[ $(nmcli radio wifi) == "enabled" ]]
}

toggle_wifi() {
    if is_wifi_enabled; then
        log "INFO" "Disabling WiFi"
        nmcli radio wifi off
        notify-send -a "WiFi Manager" -i "network-wireless-disabled" "WiFi Disabled" "WiFi has been turned off"
        echo "false"
    else
        log "INFO" "Enabling WiFi"
        notify-send -a "WiFi Manager" -i "network-wireless-acquiring" "Enabling WiFi" "Searching for networks..."
        nmcli radio wifi on
        sleep 2
        nmcli device wifi rescan 2>/dev/null
        sleep 1
        notify-send -a "WiFi Manager" -i "network-wireless" "WiFi Enabled" "Ready to connect"
        echo "true"
    fi
}

get_saved_connections() {
    nmcli -t -f NAME,TYPE connection show | grep ':802-11-wireless$' | cut -d: -f1
}

get_current_connection() {
    local iface
    iface=$(get_wifi_interface)
    nmcli -t -f NAME,TYPE,DEVICE connection show --active 2>/dev/null | grep ":802-11-wireless:${iface}" | cut -d: -f1 | head -1
}

send_notification() {
    notify-send -a "WiFi Manager" -i "network-wireless" "$1" "$2"
}

show_rofi() {
    local prompt="$1"
    shift
    if [[ -f "$ROFI_THEME" ]]; then
        rofi -dmenu -i -p "$prompt" -markup-rows -theme "$ROFI_THEME" "$@"
    else
        rofi -dmenu -i -p "$prompt" -markup-rows "$@"
    fi
}

prompt_password() {
    local ssid="$1"
    if [[ -f "$ROFI_PASSWORD_THEME" ]]; then
        rofi -dmenu -password -p "" -theme "$ROFI_PASSWORD_THEME" -mesg "Enter password for <b>$ssid</b>"
    else
        rofi -dmenu -password -p "Password for $ssid"
    fi
}

connect_to_network() {
    local ssid="$1"
    local password="$2"
    local is_saved="$3"
    local iface

    iface=$(get_wifi_interface)
    log "INFO" "Connecting to: $ssid (saved: $is_saved, interface: $iface)"

    local current
    current=$(get_current_connection)

    if [[ -n "$current" ]] && [[ "$current" != "$ssid" ]]; then
        log "INFO" "Disconnecting from: $current"
        nmcli connection down "$current" 2>/dev/null
        sleep 1
    fi

    if [[ "$is_saved" == "true" ]] && [[ -z "$password" ]]; then
        log "INFO" "Attempting saved connection"
        local result
        result=$(nmcli connection up "$ssid" 2>&1)
        if [[ $? -eq 0 ]]; then
            log "INFO" "Connected via saved profile"
            send_notification "Connected" "Connected to $ssid"
            return 0
        else
            log "WARN" "Saved connection failed: $result"
            log "INFO" "Removing old saved profile"
            nmcli connection delete "$ssid" 2>/dev/null
            sleep 1

            password=$(prompt_password "$ssid")
            [[ -z "$password" ]] && return 1
        fi
    fi

    local output
    if [[ -n "$password" ]]; then
        log "INFO" "Connecting with password"
        output=$(nmcli device wifi connect "$ssid" password "$password" ifname "$iface" 2>&1)
    else
        log "INFO" "Connecting to open network"
        output=$(nmcli device wifi connect "$ssid" ifname "$iface" 2>&1)
    fi

    if [[ $? -eq 0 ]]; then
        log "INFO" "Connected successfully"
        send_notification "Connected" "Connected to $ssid"
        return 0
    else
        log "ERROR" "Connection failed: $output"
        send_notification "Connection Failed" "Could not connect to $ssid"
        return 1
    fi
}

disconnect_current() {
    local iface
    iface=$(get_wifi_interface)
    log "INFO" "Disconnecting: $iface"

    if nmcli device disconnect "$iface" 2>/dev/null; then
        log "INFO" "Disconnected"
        send_notification "Disconnected" "WiFi disconnected"
        return 0
    fi
    log "ERROR" "Disconnect failed"
    return 1
}

forget_network() {
    local ssid="$1"
    log "INFO" "Forgetting: $ssid"

    if nmcli connection delete "$ssid" 2>/dev/null; then
        log "INFO" "Forgot: $ssid"
        send_notification "Removed" "Forgot network $ssid"
        return 0
    fi
    log "ERROR" "Failed to forget: $ssid"
    return 1
}

rescan_networks() {
    local iface
    iface=$(get_wifi_interface)
    log "INFO" "Rescanning networks on $iface"
    send_notification "Scanning" "Rescanning for WiFi networks..."
    nmcli device wifi rescan ifname "$iface" 2>/dev/null
    sleep 2
    log "INFO" "Rescan complete"
}

manage_saved_networks() {
    local saved
    saved=$(get_saved_connections)

    if [[ -z "$saved" ]]; then
        send_notification "No Networks" "No saved networks found"
        main_menu
        return
    fi

    local menu=""
    while IFS= read -r conn; do
        [[ -n "$conn" ]] && menu="${menu}  ${conn}\n"
    done <<<"$saved"
    menu="${menu}󰌑 Back"

    local sel
    sel=$(echo -e "$menu" | show_rofi "Saved")

    [[ -z "$sel" ]] && return

    if [[ "$sel" == *"Back"* ]]; then
        main_menu
        return
    fi

    local network="${sel#  }"
    local confirm
    confirm=$(echo -e "✓ Yes, forget\n✗ Cancel" | show_rofi "Forget $network?")

    [[ "$confirm" == *"Yes"* ]] && forget_network "$network"
    manage_saved_networks
}

network_action_menu() {
    local ssid="$1"
    local opts="  Disconnect\n  Forget Network\n󰌑 Back"
    local sel
    sel=$(echo -e "$opts" | show_rofi "$ssid")

    case "$sel" in
    *"Disconnect"*) disconnect_current ;;
    *"Forget"*) forget_network "$ssid" ;;
    esac
}

main_menu() {
    log "INFO" "Opening menu"

    if ! is_wifi_enabled; then
        local sel
        sel=$(echo " Enable WiFi" | show_rofi "WiFi Off")

        if [[ "$sel" == *"Enable"* ]]; then
            toggle_wifi >/dev/null
            sleep 1
            main_menu
        fi
        return
    fi

    nmcli device wifi rescan 2>/dev/null &

    local current
    current=$(get_current_connection)

    local saved
    saved=$(get_saved_connections)

    sleep 1

    local networks
    networks=$(nmcli -t -f SSID,SIGNAL,SECURITY,IN-USE device wifi list 2>/dev/null)

    declare -A seen
    declare -a net_data
    local idx=0

    while IFS=: read -r ssid signal security in_use; do
        [[ -z "$ssid" ]] && continue
        [[ -n "${seen[$ssid]}" ]] && continue
        seen[$ssid]=1

        local sig_icon
        if ((signal >= 75)); then
            sig_icon="▂▄▆█"
        elif ((signal >= 50)); then
            sig_icon="▂▄▆_"
        elif ((signal >= 25)); then
            sig_icon="▂▄__"
        else
            sig_icon="▂___"
        fi

        local is_open="false"
        local sec_icon=""
        if [[ -z "$security" || "$security" == "--" || "$security" == " " ]]; then
            is_open="true"
        fi

        local prefix=""
        [[ "$in_use" == "*" ]] && prefix="✓ "

        local is_saved="false"
        if echo "$saved" | grep -qFx "$ssid"; then
            prefix="${prefix}★ "
            is_saved="true"
        fi

        local line="${prefix}${ssid}  ${sig_icon} ${sec_icon}"
        net_data+=("${ssid}|${is_open}|${in_use}|${is_saved}|${line}")
        ((idx++))
    done <<<"$networks"

    local menu=""
    menu="  Rescan\n"
    [[ -n "$current" ]] && menu="${menu}󰣼  Disconnect from ${current}\n"
    menu="${menu}  Saved Networks\n"
    menu="${menu}  Disable WiFi\n"

    for entry in "${net_data[@]}"; do
        local line="${entry##*|}"
        menu="${menu}${line}\n"
    done

    local sel
    sel=$(printf '%b' "$menu" | show_rofi "")

    [[ -z "$sel" ]] && return

    log "INFO" "Selection: $sel"

    case "$sel" in
    *"Rescan"*)
        rescan_networks
        main_menu
        ;;
    *"Disconnect from"*)
        disconnect_current
        main_menu
        ;;
    *"Disable WiFi"*)
        toggle_wifi >/dev/null
        ;;
    *"Saved Networks"*)
        manage_saved_networks
        ;;
    *)
        for entry in "${net_data[@]}"; do
            IFS='|' read -r n_ssid n_open n_use n_saved n_line <<<"$entry"

            if [[ "$n_line" == "$sel" ]]; then
                log "INFO" "Network: $n_ssid open=$n_open use=$n_use saved=$n_saved"

                if [[ "$n_use" == "*" ]]; then
                    network_action_menu "$n_ssid"
                    main_menu
                elif [[ "$n_saved" == "true" ]]; then
                    connect_to_network "$n_ssid" "" "true"
                elif [[ "$n_open" == "true" ]]; then
                    connect_to_network "$n_ssid" "" "false"
                else
                    local pw
                    pw=$(prompt_password "$n_ssid")
                    [[ -n "$pw" ]] && connect_to_network "$n_ssid" "$pw" "false"
                fi
                break
            fi
        done
        ;;
    esac
}

case "${1:-}" in
--toggle) toggle_wifi ;;
--status) is_wifi_enabled && echo "true" || echo "false" ;;
--enable)
    nmcli radio wifi on
    send_notification "WiFi Enabled" "WiFi turned on"
    ;;
--disable)
    nmcli radio wifi off
    send_notification "WiFi Disabled" "WiFi turned off"
    ;;
--rescan)
    rescan_networks
    ;;
--help | -h)
    echo "Usage: $0 [--toggle|--status|--enable|--disable|--rescan]"
    ;;
*) main_menu ;;
esac

log "INFO" "==================== WiFi Manager Exited ===================="
