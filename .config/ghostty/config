# Font settings
font-family = "MesloLGLDZ Nerd Font"
font-size = 13

# Appearance
theme = "Matugen"

# Window Configuration
window-decoration = none
window-padding-balance = true

# Cursor Configuration
cursor-style = bar
cursor-style-blink = true

# Terminal features
mouse-hide-while-typing = true
copy-on-select = true
confirm-close-surface = false

# shell-integration = none

# launch with fullscreen mode
# fullscreen = true

# start the window in a maximized state
maximize = true

# Disable annoying copied to clipboard
# app-notifications = no-clipboard-copy,no-config-reload

# Key bindings for common actions
#keybind = ctrl+c=copy_to_clipboard
#keybind = ctrl+v=paste_from_clipboard
keybind = ctrl+shift+n=new_window
keybind = ctrl+shift+r=reload_config
keybind = ctrl+t=new_tab
keybind = ctrl+plus=increase_font_size:1
keybind = ctrl+minus=decrease_font_size:1
keybind = ctrl+zero=reset_font_size
keybind = f11=toggle_window_decorations
keybind = ctrl+shift+f=toggle_fullscreen
keybind = ctrl+shift+o=toggle_tab_overview
keybind = ctrl+shift+s=new_split:right
keybind = ctrl+shift+d=new_split:down

# Tab configuration
gtk-titlebar = false

# extra
clipboard-paste-protection = false

# Basic transparency
background-opacity = 0.9

# Blur looks better with higher opacity
# background-opacity = 0.95

# Unfocused windows more transparent
unfocused-split-opacity = 0.7
